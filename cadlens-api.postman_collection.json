{
  "info": {
    "_postman_id": "98205492c0da112d3f1be05c10d9140318efe468",
    "name": "CADLens API",
    "description": "Auto-generated Postman collection for the CADLens Node API. Maintained by the postman-agent — re-run whenever routes/validators/controllers change.\n\nQuickstart:\n1. Set `{{baseUrl}}` (defaults to http://localhost:3001).\n2. Complete OAuth via the `01 — OAuth (browser)` folder, then paste the JWT from the `#token=...` redirect fragment into `{{jwt}}`.\n3. Hit `POST /v1/keys` to mint an API key — its `key` and `id` are auto-saved to `{{apiKey}}` / `{{keyId}}`.\n4. Use `POST /v1/parse` to upload a DWG, DXF, DWF, DGN, DWFx, or PDF file — the returned `job_id` is auto-saved to `{{jobId}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 — Public",
      "description": "Unauthenticated health and JWKS endpoints.",
